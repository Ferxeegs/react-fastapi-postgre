# ============================================
# 1. PROJECT METADATA
# ============================================
PROJECT_NAME="App Name"
PROJECT_VERSION=1.0.0
DEBUG=True
# ENV: development / production (digunakan script internal)
ENV=development

# ============================================
# 2. DATABASE CONFIGURATION
# ============================================
# Kredensial untuk container 'db'
DB_NAME=db_app
DB_USER=root
DB_PASSWORD=rootpassword
DB_PORT=5432

# URL Koneksi untuk Backend (FastAPI)
# @db merujuk pada nama service di docker-compose.yml
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:${DB_PORT}/${DB_NAME}

# ============================================
# 3. SECURITY & AUTHENTICATION
# ============================================
# PENTING: Ganti SECRET_KEY ini saat naik ke server produksi!
SECRET_KEY=dJQm7iofGM7awUq4UCruj8Yy5Yu3Q1viFagkKG0eBWR
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 4. FRONTEND & GATEWAY CONFIGURATION
# ============================================
# VITE_ prefix wajib agar React bisa membaca variabel ini
VITE_API_URL=/api/v1

# CORS: Izinkan akses dari domain ini
# Gunakan format JSON Array jika backend membutuhkan parsing
BACKEND_CORS_ORIGINS=["http://localhost", "http://127.0.0.1"]

# ============================================
# 5. SERVER & LOGGING
# ============================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================
# 6. FILE UPLOAD & STORAGE
# ============================================
# MAX_UPLOAD_SIZE dalam KB (3072 = 3MB)
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads

# ============================================
# 7. INITIAL ADMIN SEEDING
# ============================================
# Akun admin default yang akan dibuat saat inisialisasi database
INIT_ADMIN_USERNAME=superadmin
INIT_ADMIN_EMAIL=superadmin@local.com
INIT_ADMIN_PASSWORD=12341234
INIT_ADMIN_FIRSTNAME=Super
INIT_ADMIN_LASTNAME=Admin

# ============================================
# 8. EMAIL CONFIGURATION (Optional)
# ============================================
# SMTP_TLS=True
# SMTP_PORT=587
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAILS_FROM_EMAIL=admin@laundrypondok.com
# EMAILS_FROM_NAME="Laundry Pondok System"